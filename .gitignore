# .NET / Visual Studio ignore rules

# Build artifacts
bin/
obj/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
*.log
*.vspscc
*.vssscc
*.cachefile
*.dbmdl
*.bak
*.backup
*.BLOB
*.pdb
*.obj
*.pch
*.ilk
*.meta
*.tmp
*.tmp_proj

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
*.userprefs
*.ncb
*.opensdf
*.sdf

# Visual Studio Code
.vscode/

# Visual Studio workspace directory
.vs/

# Rider
.idea/
*.sln.iml

# NuGet packages
*.nupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# NuGet package restore
project.lock.json
project.fragment.lock.json
artifacts/
packages/

# Mono auto generated files
mono_crash.*

# IIS Express
iisexpress/

# Azure Web Services
.publishsettings

# Temporary files
~$*
*.~*

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db

# End of file
